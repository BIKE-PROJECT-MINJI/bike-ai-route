# Local development template. Do not commit real secrets.

# Gemini is the current primary LLM provider for explanation composition.
# Keep this key only in the worker environment.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# GOOGLE_API_KEY/GOOGLE_MODEL are accepted aliases.
GOOGLE_API_KEY=
GOOGLE_MODEL=

# OPENAI_* remains compatibility-only in the settings object.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
